# =========================
# COBO Wallet MCP 示例配置
# =========================
#
# 这份文件的作用：
# 1. 告诉程序应该连接哪一个 Sepolia 测试链 RPC
# 2. 告诉程序使用哪一个测试钱包
# 3. 控制是否允许真正发起转账
# 4. 控制提案有效期、单笔限额和本地数据目录
#
# 使用方法：
# 1. 复制本文件为项目根目录下的 .env
# 2. 按中文说明替换下面的值
# 3. 只用测试链，不要填主网私钥
#
# 最简配置步骤：
# 1. 准备一个“只用于 Sepolia 测试链”的新钱包
# 2. 导出这个测试钱包的 private key（私钥）
# 3. 把私钥填到 DEMO_PRIVATE_KEY
# 4. 给这个钱包领一些 Sepolia 测试 ETH
# 5. 开发阶段先保持 DEMO_WRITE_ENABLED=false
# 6. 当你确认 RPC、私钥、测试币都没问题后，再改成 true

# SEPOLIA_RPC_URL
# 含义：Sepolia 测试链的 RPC 地址，也就是程序连接区块链的入口。
# 怎么填：
# - 最简单可以直接用一个公共 RPC
# - 更稳定的方式是换成你自己的 Infura / Alchemy / QuickNode 地址
# 注意：
# - 这是测试链地址，不是主网地址
# - 公共 RPC 适合 Demo，不适合高频或生产环境
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# DEMO_PRIVATE_KEY
# 含义：测试钱包的私钥，用于签名和发送测试链交易。
# 怎么填：
# - 只能填写 Sepolia 测试钱包私钥
# - 绝对不要填写任何主网钱包私钥
# - 如果先不想发交易，可以先保留占位值或留空，然后只做只读测试
# 格式要求：
# - 以太坊私钥本质上是 32 字节
# - 转成十六进制后是 64 位字符
# - 通常会带一个 0x 前缀，所以你最常看到的总长度是 66 个字符
# - 正确示例格式：
#   0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# - 上面只是格式示例，不是真实可用私钥
# 自检方法：
# - 必须是 0x 开头
# - 去掉 0x 后，应该正好剩下 64 位
# - 只能包含 0-9 和 a-f
# 从哪里来：
# - 你可以在 MetaMask、Rabby 等钱包里新建一个测试用账户，再导出私钥
# - 强烈建议专门新建一个“测试钱包”，不要复用你平时的钱包
# 注意：
# - 谁有私钥，谁就能控制这个钱包
# - 这项配置最敏感，不能提交到 GitHub
DEMO_PRIVATE_KEY=0xYOUR_SEPOLIA_TEST_PRIVATE_KEY

# DEMO_WRITE_ENABLED
# 含义：是否允许真正执行写操作，也就是是否允许把交易发到链上。
# 可选值：
# - false：只读模式，安全默认值
# - true：允许执行转账
# 建议：
# - 开发早期先保持 false
# - 当 RPC 和测试私钥确认无误后，再改成 true
# - 即使是 simulate 模式，确认执行提案这一步也仍然需要 true
DEMO_WRITE_ENABLED=false

# DEMO_EXECUTION_MODE
# 含义：执行模式，用来决定“确认提案”之后到底怎么处理。
# 可选值：
# - simulate：本地模拟执行，不会真的广播到区块链
# - sepolia：未来用于真实广播到 Sepolia 链
# 当前建议：
# - 先使用 simulate，把本地流程跑通
DEMO_EXECUTION_MODE=simulate

# DEMO_SIMULATED_BALANCE_ETH
# 含义：本地模拟模式下的钱包初始余额，单位是 ETH。
# 作用：
# - 只有 DEMO_EXECUTION_MODE=simulate 时才生效
# - Codex 读取余额时，会看到这个本地测试余额，而不是真实链上余额
# - 模拟转账成功后，这个余额会自动扣减
# 当前建议：
# - 为了方便测试，默认设成 50
DEMO_SIMULATED_BALANCE_ETH=50

# DEMO_REQUIRE_LOCAL_AUTH
# 含义：是否要求“本地终端再次授权”。
# 可选值：
# - false：简化模式。你只要在对话里回复“确认”，Codex 就可以直接调用确认执行。
# - true：严格模式。你除了在对话里确认，还要在本地终端再运行一次授权命令并输入 PIN。
# 当前默认：
# - false，优先保证演示流程顺手
# 注意：
# - 关闭后会更方便，但安全边界会更弱
DEMO_REQUIRE_LOCAL_AUTH=false

# DEMO_APPROVAL_PIN
# 含义：本地人工授权时需要输入的一次性 PIN。
# 使用方式：
# - 只有当 DEMO_REQUIRE_LOCAL_AUTH=true 时才会用到它
# - 当你在对话里对 Codex 说“确认”后，Codex 会把提案推进到待本地授权状态
# - 然后你需要在本地终端运行授权命令，并输入这个 PIN
# - PIN 正确后，提案才会进入 authorized 状态，允许执行一次
# 建议：
# - 改成你自己容易记住但别人猜不到的 6 位或更长数字
# - 这不是区块链私钥，而是“本地人工确认密码”
DEMO_APPROVAL_PIN=246810

# DEMO_CHAIN_ID
# 含义：目标链编号，用来防止程序连错链。
# Sepolia 的链编号是 11155111，一般不要改。
DEMO_CHAIN_ID=11155111

# DEMO_MAX_TRANSFER_ETH
# 含义：单笔交易允许发送的最大 ETH 数量。
# 作用：避免 Agent 或测试脚本一次发出过多测试币。
# 示例：0.05 表示单笔最多转 0.05 ETH
DEMO_MAX_TRANSFER_ETH=0.05

# DEMO_PROPOSAL_TTL_MINUTES
# 含义：提案有效期，单位是分钟。
# 作用：如果一条提案创建后太久没人审批，它就应该自动失效，避免旧提案被误执行。
# 示例：30 表示提案 30 分钟后过期。
DEMO_PROPOSAL_TTL_MINUTES=30

# DEMO_LOCAL_AUTH_TTL_MINUTES
# 含义：本地 PIN 授权窗口的有效期，单位是分钟。
# 作用：
# - 只有当 DEMO_REQUIRE_LOCAL_AUTH=true 时才会生效
# - 当你在本地终端输入正确 PIN 后，不会永久放行
# - 只会给这条提案一个很短的“可执行窗口”
# - 一旦超时，或者这次执行已经消耗掉授权，就必须重新做本地授权
# 示例：5 表示本地 PIN 通过后，5 分钟内必须完成这次确认执行
DEMO_LOCAL_AUTH_TTL_MINUTES=5

# DEMO_DATA_DIR
# 含义：本地数据目录，用来保存提案和审计日志。
# 一般保持默认即可。
DEMO_DATA_DIR=./data

# 配置完成后你应该得到什么结果：
# 1. `SEPOLIA_RPC_URL` 指向可用的测试链 RPC
# 2. `DEMO_PRIVATE_KEY` 是你自己的测试钱包私钥，格式正确
# 3. `DEMO_WRITE_ENABLED=false` 时项目只能读，不能发交易
# 4. `DEMO_EXECUTION_MODE=simulate` 时，确认提案只会做本地模拟，不会发到链上
# 5. `DEMO_SIMULATED_BALANCE_ETH=50` 时，simulate 模式会默认显示 50 ETH 的测试余额
# 6. 想发测试交易时，再把 `DEMO_WRITE_ENABLED` 改成 `true`
